# Production image for the EMS frontend (Kubernetes / OVH).
# Builds the Vite SPA to static files and serves them with nginx, which proxies
# /api to the backend service so the app keeps using relative /api paths.
FROM node:20-bookworm-slim AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
